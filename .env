# ═══════════════════════════════════════════════════════════
# StadiumIQ — Environment Configuration
# FIFA World Cup 2026 | Powered by Google Cloud
# ═══════════════════════════════════════════════════════════

# Flask Secret Key (change in production!)
SECRET_KEY=stadiumiq-dev-secret-key-2026

# ─── Google Gemini API (GenAI) ──────────────────────────────
# Powers: AI Chatbot, Match Previews, Crowd Recommendations,
#         Accessibility Guidance, Sustainability Tips, Translation
# Get yours: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Google Maps Platform ───────────────────────────────────
# Powers: Stadium Navigator (Maps JS API), Nearby Places,
#         Directions, Street View, Satellite Imagery
# Get yours: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, Places API, Directions API
GOOGLE_MAPS_API_KEY=

# ─── Google Analytics 4 ────────────────────────────────────
# Powers: User analytics, page views, event tracking
# Format: G-XXXXXXXXXX
# Get yours: https://analytics.google.com/
GOOGLE_ANALYTICS_ID=

# ─── Google OAuth 2.0 ──────────────────────────────────────
# Powers: "Sign in with Google" user authentication
# Get yours: https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:5000/auth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite:///stadium_iq.db

# ─── Debug Mode ────────────────────────────────────────────
FLASK_DEBUG=True
